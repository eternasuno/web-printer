{
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@mozilla/readability": "latest",
    "@types/tampermonkey": "latest",
    "happy-dom": "^20.10.2",
    "typescript": "^6.0.3",
    "vite": "latest",
    "vite-plugin-monkey": "latest",
    "vitest": "latest"
  },
  "name": "web-printer",
  "packageManager": "pnpm@11.1.0",
  "private": true,
  "scripts": {
    "build": "vite build",
    "dev": "vite build && vite preview",
    "lint": "biome check src/ test/",
    "lint:fix": "biome check --write src/ test/",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm run lint && pnpm run typecheck && pnpm run test"
  },
  "type": "module",
  "version": "0.1.0"
}
