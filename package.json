  "devDependencies": {
    "@mozilla/readability": "latest",
    "@types/tampermonkey": "latest",
    "happy-dom": "^20.9.0",
    "typescript": "^6.0.3",
    "vite": "latest",
    "vite-plugin-monkey": "latest",
    "vitest": "latest"
  }
}
